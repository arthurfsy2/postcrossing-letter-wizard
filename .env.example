# ═══════════════════════════════════════════════════════════════════
# ⚠️  重要提示 / IMPORTANT NOTICE
# ═══════════════════════════════════════════════════════════════════
#
# 此文件为配置模板，供参考使用。实际配置文件需放置在：
# This is a template file for reference. The actual config file should be placed at:
#
#     {workspace_root}/.env_postcrossing
#
# （即 postcrossing-letter-wizard/ 文件夹的父目录，不是此文件所在目录）
# (Parent directory of postcrossing-letter-wizard/, NOT this file's directory)
#
# 💡 推荐做法：让 AI 自动引导创建配置（无需手动操作）
# 💡 Recommended: Let AI guide you through the setup automatically
#
# 首次使用时，只需对 AI 说：
# First time usage, just tell AI:
#     "帮我生成明信片内容" / "Generate postcard content for me"
#
# AI 会在 Step 1 自动检测并引导你完成所有配置。
#
# ═══════════════════════════════════════════════════════════════════

# ── 邮箱凭证（必填）────────────────────────────────────────────────
# 通用变量名，支持 QQ / Gmail / Outlook / 163 / 126 / iCloud / Yahoo 等
# 脚本会根据邮箱后缀自动选择 IMAP 服务器，无需手动填写 host/port
#
# Email credentials (required). Supports QQ / Gmail / Outlook / 163 / 126 / iCloud / Yahoo.
# IMAP server is auto-detected based on email suffix.
EMAIL_ACCOUNT=your@email.com
EMAIL_AUTH_CODE=your_auth_code_or_app_password

# ── IMAP 手动覆盖（可选，企业邮箱或不在内置列表中的邮箱使用）────────
# Manual IMAP override (optional, for enterprise or custom mail servers)
# IMAP_HOST=imap.yourdomain.com
# IMAP_PORT=993
# IMAP_TLS=true
# IMAP_REJECT_UNAUTHORIZED=true

# ── Postcrossing 配置（首次使用时 AI 会询问并自动填写）────────────────
# 你的 Postcrossing 国家编码（用于搜索已发送的邮件主题，如 CN、US、DE）
# Your Postcrossing country code (for searching email subjects, e.g., CN, US, DE)
# POSTCARD_COUNTRY_CODE=

# 寄信城市（用于正文中的 "Greetings from ___" 和天气估算，如 Shenzhen、Beijing）
# Sender city (used for "Greetings from ___" and weather estimation, e.g., Shenzhen, Beijing)
# POSTCARD_SENDER_CITY=

# ── 语言设置（首次使用时 AI 会询问并自动填写）────────────────────────
# 输出语言：en=英文, zh=中文
# Output language: en=English, zh=Chinese
# LANG=
