# Postcrossing Letter Wizard Configuration
# ============================================

# 邮箱账号 / Email Account
# 填写你的完整邮箱地址（如：user@gmail.com, 12345@qq.com）
EMAIL_ACCOUNT=your_email@example.com

# 邮箱授权码 / Email Auth Code
# 注意：不是邮箱登录密码！需要在邮箱设置中生成"应用专用密码"或"授权码"
# QQ 邮箱：设置 → 账户 → 开启 IMAP/SMTP 服务 → 生成授权码
# Gmail：安全性 → 两步验证 → 应用专用密码
EMAIL_AUTH_CODE=your_auth_code_here

# ============================================
# Postcrossing 配置 / Postcrossing Settings
# ============================================

# 国家 2 位编码（用于搜索邮件主题中的 Postcard ID）
# 中国大陆：CN, 美国：US, 台湾：TW, 香港：HK
POSTCARD_COUNTRY_CODE=CN

# 寄信城市（用于正文 "Greetings from ___" + 天气估算）
# 请填写城市英文名（如：Beijing, Shanghai, Shenzhen）
POSTCARD_SENDER_CITY=YourCity

# ============================================
# 语言设置 / Language Setting
# ============================================
# en = 英文输出，zh = 中文输出
LANG=en

# ============================================
# 邮件搜索配置（可选）/ Email Search Settings (Optional)
# ============================================

# Postcrossing 邮件所在文件夹名称
# QQ 邮箱示例：Postcrossing_sent
# Gmail 示例：[Gmail]/所有邮件
# 留空则默认在 INBOX 中搜索
# POSTCROSSING_FOLDER=Postcrossing_sent

# 搜索日期范围（YYYY-MM-DD 格式，留空表示全部历史）
# POSTCROSSING_DATE=2026-01-29

# ============================================
# 高级 IMAP 配置（可选，一般不需要）
# Advanced IMAP Settings (Optional)
# ============================================
# 以下配置用于覆盖自动推断的 IMAP 设置，一般用户无需填写

# IMAP 服务器地址（如：imap.qq.com, imap.gmail.com）
# IMAP_HOST=

# IMAP 端口（默认 993）
# IMAP_PORT=

# 是否启用 TLS（默认 true）
# IMAP_TLS=true

# 是否验证 TLS 证书（QQ 邮箱建议设为 false）
# IMAP_REJECT_UNAUTHORIZED=false
